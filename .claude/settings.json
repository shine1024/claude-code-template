{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(mvn:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "WebSearch"
    ],
    "deny": []
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/slack-notify/task-start.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-update/check-update.bat"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/slack-notify/notify.js"
          }
        ]
      }
    ]
  }
}
